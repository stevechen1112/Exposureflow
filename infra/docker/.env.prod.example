# Copy to .env on the server: cp .env.prod.example .env && fill secrets

APP_ENV=staging
APP_BASE_URL=https://app.kakusinn.com
API_BASE_URL=https://app.kakusinn.com

POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql+asyncpg://exposureflow:change-me-strong-password@postgres:5432/exposureflow
REDIS_URL=redis://redis:6379/0

JWT_SECRET=change-me-jwt-secret
ENCRYPTION_KEY=change-me-32-byte-key-production

NEXT_PUBLIC_API_BASE_URL=https://app.kakusinn.com
NEXT_PUBLIC_ENABLE_DEV_AUTH=true

# Step 2 (Clerk) / Step 3 (GSC OAuth) — add when ready
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# CLERK_SECRET_KEY=
